{
	"name": "n8n-nodes-velagain",
	"version": "0.1.2",
	"description": "n8n community node for Velagain — booking automation triggers and actions.",
	"keywords": [
		"n8n-community-node-package",
		"velagain",
		"booking",
		"line",
		"scheduling"
	],
	"license": "MIT",
	"homepage": "https://github.com/leonsgithub/n8n-nodes-velagain#readme",
	"author": {
		"name": "Velagain",
		"email": "npm-package-velagain.numeric635@passmail.net"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/leonsgithub/n8n-nodes-velagain.git"
	},
	"engines": {
		"node": ">=18.10"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && npm run copy:icons",
		"copy:icons": "mkdir -p dist/nodes/Velagain dist/nodes/VelagainTrigger && cp nodes/Velagain/velagain.svg dist/nodes/Velagain/ && cp nodes/VelagainTrigger/velagain.svg dist/nodes/VelagainTrigger/",
		"dev": "tsc --watch",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/VelagainApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Velagain/Velagain.node.js",
			"dist/nodes/VelagainTrigger/VelagainTrigger.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@types/node": "^20.19.43",
		"@typescript-eslint/parser": "^7.18.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"n8n-workflow": "^1.60.0",
		"typescript": "^5.6.0"
	},
	"bugs": {
		"url": "https://github.com/leonsgithub/n8n-nodes-velagain/issues"
	}
}
